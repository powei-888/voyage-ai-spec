{
  "name": "voyage-ai",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace @voyage/web",
    "dev:api": "npm run dev --workspace @voyage/api",
    "build": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "test": "npm run test --workspaces",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "prisma:generate": "npm run prisma:generate --workspace @voyage/api",
    "prisma:validate": "npm run prisma:validate --workspace @voyage/api"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "postcss": "8.5.10",
    "multer": "2.2.0"
  }
}
